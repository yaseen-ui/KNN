# Server Configuration
PORT=3000
NODE_ENV=development

# Similarity Strategy (options: levenshtein, prefix, jaccard)
DEFAULT_STRATEGY=levenshtein

# Cache Configuration
CACHE_ENABLED=true
CACHE_TTL=300000
CACHE_MAX_SIZE=1000

# Data Storage
DATA_DIR=./data
TOKENS_FILE=tokens.json

# Logging (options: debug, info, warn, error)
LOG_LEVEL=info
LOG_FORMAT=simple
